# URL base del Backend para llamadas directas de la API (opcional).
# Se puede dejar vacío en desarrollo si se prefiere usar el proxy de Vite.
# Ejemplo para producción: https://neohw-backend-production.up.railway.app
VITE_API_URL=

# URL de destino para el proxy del servidor de desarrollo de Vite (redirecciona las peticiones locales).
# Local: http://localhost:3000
# Producción/Desplegado: https://neohw-backend-production.up.railway.app
VITE_DEV_PROXY_TARGET=http://localhost:3000

# ID de Cliente de Google OAuth 2.0 (requerido para el botón de login/registro con Google en el navegador).
VITE_GOOGLE_CLIENT_ID=

# ID de Aplicación de Facebook SDK (requerido para el flujo de login con Facebook en el navegador).
VITE_FACEBOOK_APP_ID=
